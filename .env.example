# plc-workflows-mpc connection configuration (copy to .env and fill in)
# These map to the manifest.json connection_params.

# Forge hub gRPC endpoint the spoke registers with and exchanges data through.
FORGE_HUB_ENDPOINT=grpc://localhost:50051

# Rockwell Logix EtherNet/IP path 'ip[/slot]' (addressed via pycomm3).
# Leave blank to operate purely hub-mediated (no direct PLC link).
PLC_PATH=

# MPC control period in seconds (how often the controller computes a move).
CONTROL_PERIOD_S=5.0

# Seconds the PLC link must be healthy before the supervisor (re)arms.
REARM_HOLDOFF_S=30.0

# PLC heartbeat must advance within this many seconds, or the link is unhealthy.
HEARTBEAT_TIMEOUT_S=2.0

# Soft setpoint clamps (the PLC enforces the hard clamps). Leave blank for none.
SP_MIN=
SP_MAX=

# Commissioning safety: if true, read and solve but never write. Default true.
DRY_RUN=true

# Verify TLS/SSL certificates for the hub connection.
VERIFY_SSL=true
